{
  "manifest_version": 3,
  "name": "催促ツール (Saisoku)",
  "version": "1.0",
  "description": "LINE Chat催促メッセージ自動送信（仮査定・本査定・梱包キット）",
  "permissions": [
    "scripting",
    "tabs",
    "debugger",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://chat.line.biz/*",
    "https://*.cybozu.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
